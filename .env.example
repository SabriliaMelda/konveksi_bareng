# Kosongkan untuk development (otomatis per platform)
# Isi URL production saat deploy, misal: API_URL=https://api.domain.com
API_URL=

# Situasi: kamu di branch milikmu, mau ambil perubahan dari branch manapun tanpa checkout.

# 1. Pastikan branch lokal kamu up-to-date dulu
git fetch origin

# 2. Update branch orang tersebut di lokal milikmu (tanpa checkout)
git fetch origin [nama_branch]:[nama_branch]

# 3. Merge branch orang tersebut ke branch milikmu dengan --no-ff
git merge --no-ff [nama_branch]

# Situasi: kamu di branch milikmu, mau ambil perubahan dari branch manapun menggunakan checkout.
# Situasi ini lebih umum, tapi ada langkah tambahan yaitu checkout ke branch orang tersebut dulu.

# 1. Pastikan branch lokal kamu up-to-date dulu
git fetch origin

# 2. Pindah ke branch orang tersebut, lalu pull
git checkout [nama_branch]
git pull origin [nama_branch]

# 3. Balik ke branch [nama_branch_milikmu], lalu merge
git checkout [nama_branch_milikmu]
git merge --no-ff [nama_branch]

        